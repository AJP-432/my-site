{
	"editor.formatOnSave": true,
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"files.eol": "\n",
	"files.exclude": {
		"**/.git": true,
		"**/.DS_Store": true
	},
	"typescript.preferences.importModuleSpecifier": "relative",
	"files.associations": {
		"*.css": "tailwindcss"
	},
	"github.copilot.chat.codeGeneration.instructions": [
		{ "file": "./.vscode/prompts/svelte5.txt" },
		{ "file": "./.vscode/prompts/tailwindv4.txt" },
		{ "file": "./.vscode/prompts/daisyui.md" }
	]
}
